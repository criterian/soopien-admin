# Soopien Admin — environment
# Copy to .env.local and fill in. .env.local is gitignored.

# Supabase project (self-hosted). Used for admin login (Supabase Auth).
NEXT_PUBLIC_SUPABASE_URL=https://soopiendb.gacara.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key — SERVER ONLY, never exposed to the browser. Grants full
# RLS-bypassing access; the admin data layer uses it exclusively server-side.
# Get it from the Supabase dashboard → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# The Hono API (apps/api) base URL — used for actions with existing business
# logic (payout generation, billing-provider switch).
API_URL=http://localhost:8787
